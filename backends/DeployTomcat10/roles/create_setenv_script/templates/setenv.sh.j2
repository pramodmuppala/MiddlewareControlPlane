#!/bin/bash

# ==============================
# Tomcat 10 Environment Settings
# ==============================

# Set CATALINA_HOME (Tomcat installation directory)
export CATALINA_HOME={{ tomcat.catalina_home }}

# Set CATALINA_BASE (Instance-specific directory)
# If you are running a single instance, this can be the same as CATALINA_HOME
export CATALINA_BASE={{ tomcat.catalina_base }}

# Optional: Set Java Home (recommended)
export JAVA_HOME={{ tomcat.java_home }}

# Optional: JVM Options
export CATALINA_OPTS="$CATALINA_OPTS {{ tomcat.catalina_opts | default('-Xms512m -Xmx1024m -XX:+UseG1GC') }}"

# Optional: JPDA Debugging (uncomment if needed)
# export JPDA_OPTS="-agentlib:jdwp=transport=dt_socket,address=*:8000,server=y,suspend=n"

# Optional: File Encoding
export JAVA_OPTS="$JAVA_OPTS -Dfile.encoding=UTF-8"

echo "Using CATALINA_HOME: $CATALINA_HOME"
echo "Using CATALINA_BASE: $CATALINA_BASE"

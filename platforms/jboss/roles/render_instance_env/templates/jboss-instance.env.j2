# Managed by Ansible
export JAVA_HOME="{{ jboss.java_home }}"
export JBOSS_HOME="{{ jboss.install_home }}/{{ jboss.install_product_version }}"
export JBOSS_BASE_DIR="{{ instance_home }}"
export JBOSS_INSTANCE_NAME="{{ instance_name }}"
export JBOSS_HTTP_PORT="{{ instance_http_port }}"
export JBOSS_HTTPS_PORT="{{ instance_https_port }}"
export JBOSS_MANAGEMENT_PORT="{{ instance_management_port }}"
export JBOSS_AJP_PORT="{{ instance_ajp_port }}"
export JAVA_OPTS="${JAVA_OPTS:-} -Xms{{ jboss.java_opts.heap_min }} -Xmx{{ jboss.java_opts.heap_max }} -XX:MaxMetaspaceSize={{ jboss.java_opts.metaspace_max }} {{ jboss.java_opts.extra }} -Djboss.server.base.dir={{ instance_home }} -Djboss.bind.address={{ jboss.bind_address }} -Djboss.bind.address.management={{ jboss.management_bind_address }}"

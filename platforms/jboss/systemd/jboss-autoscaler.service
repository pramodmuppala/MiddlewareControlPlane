[Unit]
Description=JBoss EAP autoscaler with optional OpenAI policy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/jboss-autoscaler
Environment=OPENAI_MODEL=gpt-4o-2024-08-06
ExecStart=/usr/bin/python3 /opt/jboss-autoscaler/jboss_autoscaler.py --use-llm --inventory hosts --playbook Deploy.yml
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
